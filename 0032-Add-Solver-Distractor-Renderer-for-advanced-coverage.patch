+  </style>
+</head>
+<body>
+  <h1>Geometry OS — Advanced Circle Angles / Geometric Mean Pipeline Test</h1>
+  <p>Covers 4 new templates: two-chords interior angle, exterior secant/tangent angle, tangent-chord angle, and the right-triangle altitude geometric mean. Runs the full pipeline across 40 seeds each (160 total runs), a full 61-template regression check, and confirms a full 61-question quiz (every certified template, zero repeats) composes and prints correctly.</p>
+  <button id="runTestButton">Run Advanced Coverage Pipeline Test</button>
+  <pre id="output">Ready.</pre>
+  <div id="samples"></div>
+
+  <script>
+    const button = document.getElementById("runTestButton");
+    const output = document.getElementById("output");
+    const samplesContainer = document.getElementById("samples");
+
+    const newTemplates = [
+      "circle_angle_two_chords_calculation",
+      "circle_angle_exterior_calculation",
+      "tangent_chord_angle_calculation",
+      "right_triangle_altitude_geometric_mean_calculation"
+    ];
+
+    const SEEDS_PER_NEW_TEMPLATE = 40;
+
+    function assert(condition, message) {
+      if (!condition) throw new Error(message);
+    }
+
+    function renderSample(rendered) {
+      const wrapper = document.createElement("div");
+      wrapper.className = "sample";
+      const heading = document.createElement("h3");
+      heading.textContent = rendered.templateId;
+      wrapper.appendChild(heading);
+      const prompt = document.createElement("p");
+      prompt.textContent = rendered.promptText;
+      wrapper.appendChild(prompt);
+      const list = document.createElement("ul");
+      rendered.choices.forEach((choice) => {
+        const item = document.createElement("li");
+        item.textContent = `${choice.label}) ${JSON.stringify(choice.text)}`;
+        if (choice.isCorrect) item.className = "correct";
+        list.appendChild(item);
+      });
+      wrapper.appendChild(list);
+      samplesContainer.appendChild(wrapper);
+    }
+
+    button.addEventListener("click", async () => {
+      button.disabled = true;
+      output.textContent = "Loading Geometry OS modules...";
+      samplesContainer.innerHTML = "";
+
+      try {
+        const resolverModule = await import("../src/geometry/templates/geometryTemplateResolver.js");
+        const generatorModule = await import("../src/geometry/generation/geometryVariableGenerator.js");
+        const solverModule = await import("../src/engine/solver/geometrySolver.js");
+        const distractorModule = await import("../src/engine/distractors/geometryDistractorEngine.js");
+        const rendererModule = await import("../src/engine/prompts/geometryPromptRenderer.js");
+        const validationModule = await import("../src/geometry/templates/geometryTemplateValidationContract.js");
+        const composerModule = await import("../src/engine/geometryQuizComposer.js");
+        const printerModule = await import("../src/engine/geometryQuizPrinter.js");
+
+        const { geometryTemplateResolver } = resolverModule;
+        const { geometryVariableGenerator } = generatorModule;
+        const { geometrySolver } = solverModule;
+        const { geometryDistractorEngine } = distractorModule;
+        const { geometryPromptRenderer } = rendererModule;
+        const { geometryTemplateValidationContract } = validationModule;
+        const { geometryQuizComposer } = composerModule;
+        const { geometryQuizPrinter } = printerModule;
+
+        output.textContent = "Modules loaded. Validating registry...";
+
+        const registryValidation = geometryTemplateValidationContract.validateRegistry();
+        assert(registryValidation.valid, `Registry validation failed: ${JSON.stringify(registryValidation.errors)}`);
+        assert(registryValidation.templateCount === 61, `Expected 61 certified templates, found ${registryValidation.templateCount}.`);
+
+        output.textContent = `Registry OK (61 templates). Running new-template pipeline (${newTemplates.length} templates x ${SEEDS_PER_NEW_TEMPLATE} seeds)...`;
+
+        const failures = [];
+        let totalRuns = 0;
+        const exampleByTemplate = {};
+
+        newTemplates.forEach((templateId) => {
+          for (let seedIndex = 0; seedIndex < SEEDS_PER_NEW_TEMPLATE; seedIndex++) {
+            totalRuns += 1;
+
+            const resolution = geometryTemplateResolver.resolve({ templateId });
+            if (!resolution.resolved) { failures.push({ templateId, seedIndex, stage: "resolver", errors: resolution.errors }); continue; }
+
+            const generation = geometryVariableGenerator.generate(resolution, {
+              seed: `adv-test-${templateId}-${seedIndex}`,
+              generationIndex: seedIndex
+            });
+            if (!generation.generated) { failures.push({ templateId, seedIndex, stage: "generator", errors: generation.errors }); continue; }
+
+            const solveResult = geometrySolver.solve({
+              templateId,
+              problemTypeId: resolution.problemTypeId,
+              variables: generation.variables
+            });
+            if (!solveResult.solved) { failures.push({ templateId, seedIndex, stage: "solver", errors: solveResult.errors }); continue; }
+
+            const distractorResult = geometryDistractorEngine.generate({
+              templateId,
+              problemTypeId: resolution.problemTypeId,
+              variables: generation.variables,
+              correctAnswer: solveResult.correctAnswer,
+              acceptableAnswers: solveResult.acceptableAnswers
+            });
+            const distractorsValid = distractorResult.generated &&
+              Array.isArray(distractorResult.distractors) &&
+              distractorResult.distractors.length === 3 &&
+              new Set(distractorResult.distractors.map((d) => JSON.stringify(d))).size === 3;
+            if (!distractorsValid) { failures.push({ templateId, seedIndex, stage: "distractors", errors: distractorResult.errors }); continue; }
+
+            const rendered = geometryPromptRenderer.render({
+              templateId,
+              problemTypeId: resolution.problemTypeId,
+              variables: generation.variables,
+              correctAnswer: solveResult.correctAnswer,
+              distractors: distractorResult.distractors,
+              seed: `adv-render-${templateId}-${seedIndex}`
+            });
+
+            const valid = rendered.rendered &&
+              rendered.choices.length === 4 &&
+              rendered.choices.filter((c) => c.isCorrect).length === 1 &&
+              !rendered.promptText.includes("undefined") &&
+              !rendered.promptText.includes("NaN");
+
+            if (!valid) { failures.push({ templateId, seedIndex, stage: "renderer" }); continue; }
+
+            if (!exampleByTemplate[templateId]) {
+              exampleByTemplate[templateId] = rendered;
+            }
+          }
+        });
+
+        assert(failures.length === 0, `Pipeline failed for ${failures.length} of ${totalRuns} runs. First failure: ${JSON.stringify(failures[0])}`);
+
+        output.textContent = "New-template pipeline OK. Running full 61-template regression...";
+
+        const allTemplateIds = geometryVariableGenerator.getSupportedTemplateIds();
+        let regressionPass = 0;
+        allTemplateIds.forEach((templateId, index) => {
+          const resolution = geometryTemplateResolver.resolve({ templateId });
+          const generation = geometryVariableGenerator.generate(resolution, { seed: `regression61-${templateId}`, generationIndex: index });
+          const solveResult = geometrySolver.solve({ templateId, problemTypeId: resolution.problemTypeId, variables: generation.variables });
+          const distractorResult = geometryDistractorEngine.generate({ templateId, problemTypeId: resolution.problemTypeId, variables: generation.variables, correctAnswer: solveResult.correctAnswer, acceptableAnswers: solveResult.acceptableAnswers });
+          const rendered = geometryPromptRenderer.render({ templateId, problemTypeId: resolution.problemTypeId, variables: generation.variables, correctAnswer: solveResult.correctAnswer, distractors: distractorResult.distractors, seed: `regression61-render-${templateId}` });
+          if (resolution.resolved && generation.generated && solveResult.solved && distractorResult.generated && rendered.rendered && rendered.choices.length === 4) {
+            regressionPass += 1;
+          }
+        });
+
+        assert(regressionPass === allTemplateIds.length, `Full regression failed: only ${regressionPass}/${allTemplateIds.length} templates passed the complete pipeline.`);
+
+        output.textContent = "Regression OK. Testing a full 61-question quiz (every certified template, zero repeats)...";
+
+        const fullQuiz = geometryQuizComposer.compose({ questionCount: allTemplateIds.length, seed: "full-quiz-check" });
+        assert(fullQuiz.composed, "Failed to compose a quiz using all 61 certified templates.");
+        assert(new Set(fullQuiz.quiz.templateIdsUsed).size === allTemplateIds.length, "Full quiz did not use every template exactly once.");
+
+        const printed = geometryQuizPrinter.renderHtml(fullQuiz.quiz, { title: "Full Certified Template Quiz" });
+        assert(printed.rendered, "Quiz Printer failed to render the full 61-question quiz.");
+
+        const result = {
+          test: "Advanced Circle Angles / Geometric Mean Pipeline",
+          registryTemplateCount: registryValidation.templateCount,
+          registryValid: registryValidation.valid,
+          newTemplateCount: newTemplates.length,
+          seedsPerTemplate: SEEDS_PER_NEW_TEMPLATE,
+          totalNewTemplateRuns: totalRuns,
+          newTemplateFailureCount: failures.length,
+          fullRegressionTemplateCount: allTemplateIds.length,
+          fullRegressionPassCount: regressionPass,
+          fullQuizComposedWithAllTemplates: true,
+          fullQuizPrinterOk: true,
+          pass: true
+        };
+
+        output.textContent = "PASS — Advanced Coverage Pipeline (" + totalRuns + " runs, 0 failures; full " + allTemplateIds.length + "-template regression: " + regressionPass + "/" + allTemplateIds.length + "; full-quiz test OK)\n\n" + JSON.stringify(result, null, 2);
+
+        newTemplates.forEach((templateId) => {
+          if (exampleByTemplate[templateId]) renderSample(exampleByTemplate[templateId]);
+        });
+      } catch (error) {
+        const failureResult = {
+          test: "Advanced Coverage Pipeline",
+          pass: false,
+          errorName: error && error.name ? error.name : "Error",
+          error: error instanceof Error ? error.message : String(error),
+          stack: error instanceof Error ? error.stack : null
+        };
+        output.textContent = "FAIL — Advanced Coverage Pipeline\n\n" + JSON.stringify(failureResult, null, 2);
+      } finally {
+        button.disabled = false;
+      }
+    });
+  </script>
