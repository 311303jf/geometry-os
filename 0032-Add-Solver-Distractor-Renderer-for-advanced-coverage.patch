+
+  tangent_chord_angle_calculation: (v, correct) =>
+    distractTangentChordAngle(v, correct),
+
+  right_triangle_altitude_geometric_mean_calculation: (v, correct) =>
+    distractRightTriangleAltitudeGeometricMean(v, correct)
 });
 
